# Database
MONGODB_URI=mongodb://localhost:27017/calories-tracker

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=your_webhook_url

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# JWT
JWT_SECRET=your_jwt_secret

# CORS
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=meals
CLOUDFLARE_R2_PUBLIC_URL=https://your-bucket-name.your-domain.com

# Payme Payment Gateway
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_MERCHANT_KEY=your_payme_merchant_key
PAYME_API_KEY=your_payme_api_key
PAYME_CALLBACK_URL=https://yourdomain.com/api/payments/payme/callback

# Subscription Configuration
ORDER_EXPIRE_TIME=12

# Server
PORT=3000
NODE_ENV=development
